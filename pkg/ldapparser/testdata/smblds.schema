( 1.2.840.113556.1.5.183 NAME 'dSUISettings' SUP top STRUCTURAL MAY (msDS-Non-Security-Group-Extra-Classes $ msDS-Security-Group-Extra-Classes $ msDS-FilterContainers $ dSUIShellMaximum $ dSUIAdminNotification $ dSUIAdminMaximum ) )
( 1.2.840.113556.1.5.53 NAME 'typeLibrary' SUP top STRUCTURAL MAY (cOMUniqueLIBID $ cOMInterfaceID $ cOMClassID ) )
( 1.2.840.113556.1.5.253 NAME 'msFVE-RecoveryInformation' SUP top STRUCTURAL MUST (msFVE-RecoveryGuid $ msFVE-RecoveryPassword ) MAY (msFVE-VolumeGuid $ msFVE-KeyPackage ) )
( 0.9.2342.19200300.100.4.7 NAME 'room' SUP top STRUCTURAL MUST (cn ) MAY (location $ telephoneNumber $ seeAlso $ description $ roomNumber ) )
( 1.2.840.113556.1.5.82 NAME 'rpcProfile' SUP rpcEntry STRUCTURAL )

